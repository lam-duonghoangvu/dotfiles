tap "cargo-lambda/tap", "https://github.com/cargo-lambda/homebrew-tap.git", trusted: true

# Developer tools
brew "colima"
brew "container"
brew "sqlite"
brew "awscli"
brew "glab"
brew "infisical"
brew "opencode"

# Languages
brew "go"
brew "rust"
brew "cargo-lambda/tap/cargo-lambda"
brew "swift-format"
brew "swiftlint"

# Personal
brew "mole"
brew "hugo"

# Developer tools
cask "datagrip"
cask "antigravity-cli"
cask "claude-code@latest"
cask "codex"

# Messaging
cask "beeper"
cask "discord"
cask "zalo"

# Others
